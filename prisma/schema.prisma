// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum AuditAction {
  LOGIN
  LOGIN_FAILED
  LOGOUT
  TOKEN_REFRESHED
  PASSWORD_CHANGED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  PERMISSION_GRANTED
  PERMISSION_REVOKED
}

enum Gender {
  MALE
  FEMALE
}

enum LanguageLevel {
  NONE
  BASIC
  INTERMEDIATE
  ADVANCED
  NATIVE
}

enum EducationLevel {
  HIGH_SCHOOL
  VOCATIONAL
  DIPLOMA
  BACHELOR
  MASTER
  PHD
}

enum GraduatedFrom {
  DOMESTIC
  ABROAD
}

enum Country {
  LAOS
  THAILAND
  VIETNAM
  CHINA
  CAMBODIA
  MYANMAR
  MALAYSIA
  SINGAPORE
  JAPAN
  SOUTH_KOREA
  USA
  UK
  AUSTRALIA
  FRANCE
  GERMANY
  RUSSIA
  CANADA
  OTHER
}

enum TripType {
  DOMESTIC
  INTERNATIONAL
}

enum LaoProvince {
  VIENTIANE_CAPITAL
  PHONGSALI
  LUANG_NAMTHA
  OUDOMXAI
  BOKEO
  LUANG_PRABANG
  HUAPHANH
  XAYABOULI
  XIANGKHOUANG
  VIENTIANE
  BORIKHAMXAI
  KHAMMOUANE
  SAVANNAKHET
  SALAVAN
  SEKONG
  CHAMPASAK
  ATTAPEU
  XAISOMBOUN
}

enum TripStatus {
  DRAFT
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique
  username    String    @unique
  password    String
  role        UserRole  @default(EMPLOYEE)
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")

  photoUrl         String?         @map("photo_url")
  firstName        String          @map("first_name")
  lastName         String          @map("last_name")
  gender           Gender?
  educationLevel   EducationLevel? @map("education_level")
  institutionName  String?         @map("institution_name")
  graduatedFrom    GraduatedFrom?  @map("graduated_from")
  graduatedCountry Country?        @map("graduated_country")
  fieldOfStudy     String?         @map("field_of_study")
  englishLevel     LanguageLevel?  @map("english_level")
  vietnameseLevel  LanguageLevel?  @map("vietnamese_level")
  chineseLevel     LanguageLevel?  @map("chinese_level")
  otherLanguages   String?         @map("other_languages")
  passportExpiry   DateTime?       @map("passport_expiry") @db.Date

  departmentId String? @map("department_id") @db.Uuid
  positionId   String? @map("position_id") @db.Uuid

  mustChangePassword Boolean @default(true) @map("must_change_password")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
  businessTrips BusinessTrip[] @relation("TripOwner")
  verifiedTrips BusinessTrip[] @relation("TripVerifier")
  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position      Position?      @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@index([role])
  @@index([lastName])
  @@index([passportExpiry])
  @@index([departmentId])
  @@index([positionId])
  @@map("users")
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  users User[]

  @@map("departments")
}

model Position {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  users User[]

  @@map("positions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  action     AuditAction
  resource   String?
  resourceId String?     @map("resource_id")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  metadata   Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model ExTable {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @map("created_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String   @map("updated_by")

  @@map("ex_table")
}

model Banner {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  subtitle  String?
  imageUrl  String?  @map("image_url")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @map("created_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String   @map("updated_by")

  @@index([isActive, sortOrder])
  @@map("banner")
}

/// Singleton table holding site-wide branding (logo) and footer content.
/// Exactly one row exists, identified by SITE_SETTING_SINGLETON_ID.
model SiteSetting {
  id             String   @id @db.Uuid
  logoUrl        String?  @map("logo_url")
  brandName      String?  @map("brand_name")
  description    String?  @map("description")
  footerText     String?  @map("footer_text")
  linksHeading   String?  @map("links_heading")
  footerLinks    Json     @default("[]") @map("footer_links")
  contactEmail   String?  @map("contact_email")
  contactPhone   String?  @map("contact_phone")
  contactAddress String?  @map("contact_address")
  facebookUrl    String?  @map("facebook_url")
  instagramUrl   String?  @map("instagram_url")
  whatsappUrl    String?  @map("whatsapp_url")
  linkedinUrl    String?  @map("linkedin_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  updatedBy      String   @map("updated_by")

  @@map("site_setting")
}

model BusinessTrip {
  id                  String       @id @default(uuid()) @db.Uuid
  title               String
  tripType            TripType     @map("trip_type")
  destinationProvince LaoProvince? @map("destination_province")
  destinationCountry  Country?     @map("destination_country")
  departureDate       DateTime     @map("departure_date") @db.Date
  returnDate          DateTime     @map("return_date") @db.Date
  status              TripStatus   @default(DRAFT)

  submittedAt     DateTime? @map("submitted_at")
  verifiedAt      DateTime? @map("verified_at")
  verifiedById    String?   @map("verified_by_id") @db.Uuid
  rejectionReason String?   @map("rejection_reason") @db.Text

  userId String @map("user_id") @db.Uuid
  user   User   @relation("TripOwner", fields: [userId], references: [id], onDelete: Restrict)

  verifiedBy User? @relation("TripVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([departureDate])
  @@map("business_trips")
}
