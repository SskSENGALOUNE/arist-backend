# ───── HTTP ─────
# Comma-separated list, or "*" for all
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
BODY_LIMIT=1mb

# ───── Rate Limiting ─────
THROTTLE_TTL_MS=60000
