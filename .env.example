# ───── Runtime ─────
NODE_ENV=development
PORT=8000
SERVICE_NAME=payment-center
LOG_LEVEL=info

# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://postgres.oldjcdgwkdckmizvepdw:Souk%40160520%21@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session-mode pooler (port 5432) — used by Prisma Migrate
DIRECT_URL="postgresql://postgres.oldjcdgwkdckmizvepdw:Souk%40160520%21@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ───── HTTP ─────
# Comma-separated list, or "*" for all
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
BODY_LIMIT=1mb

# ───── Rate Limiting ─────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ───── Auth / JWT ─────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10